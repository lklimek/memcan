{
  "description": "Setup check on session start; auto-extract learnings on agent stop and pre-compact",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "test -x ${CLAUDE_PLUGIN_ROOT}/bin/memcan-cli || echo 'MemCan binaries not found. Run: bash ${CLAUDE_PLUGIN_ROOT}/setup.sh'",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/memcan-cli extract",
            "async": true,
            "timeout": 120
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/memcan-cli extract",
            "async": true,
            "timeout": 120
          }
        ]
      }
    ]
  }
}
