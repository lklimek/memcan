# Ollama (external — not managed by this compose)
OLLAMA_URL=http://YOUR_OLLAMA_HOST:11434
OLLAMA_LLM_MODEL=gemma3n:e4b
OLLAMA_EMBED_MODEL=qwen3-embedding:4b

# Ollama API key (Bearer token) — used by the ollama Python client.
# Set this when Ollama is behind a reverse proxy with Bearer auth.
# Generate with: openssl rand -base64 32
# OLLAMA_API_KEY=

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=mindojo
QDRANT_EMBED_DIMS=2560

# Neo4j (optional — only used with --profile graph)
NEO4J_ENABLED=false
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME  # generate with: openssl rand -base64 32

# Default user ID for memory scoping
DEFAULT_USER_ID=global
TECH_STACK=

# Log file path (empty or missing = logging disabled)
# LOG_FILE=~/.local/share/mindojo/mindojo-mcp.log

# Traefik reverse proxy (optional — for remote access with TLS + basic auth)
QDRANT_DOMAIN=qdrant.example.com
NEO4J_DOMAIN=neo4j.example.com
TRAEFIK_AUTH=GENERATE_ME  # generate with: htpasswd -nb user password | sed 's/\$/\$\$/g'
