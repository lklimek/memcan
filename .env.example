# Ollama (external — not managed by this compose)
OLLAMA_URL=http://192.168.1.100:11434
OLLAMA_LLM_MODEL=qwen2.5:14b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=ai_brain
QDRANT_EMBED_DIMS=768

# Neo4j (optional — only used with --profile graph)
NEO4J_ENABLED=false
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# Default user ID for memory scoping
DEFAULT_USER_ID=global

# Traefik (for dashboard access)
QDRANT_DOMAIN=qdrant.example.com
NEO4J_DOMAIN=neo4j.example.com
TRAEFIK_AUTH=user:$$apr1$$...  # htpasswd -nb user password | sed 's/\$/\$\$/g'
