# --- MemCan Server ---

# Server bind address (Docker overrides to 0.0.0.0:8191)
# MEMCAN_LISTEN=127.0.0.1:8191

# Bearer token auth for MCP API
# MEMCAN_API_KEY=your-secret-key

# Server URL for thin clients (memcan)
# MEMCAN_URL=http://localhost:8190

# Log file path (omit for stdout, used in Docker)
# MEMCAN_LOG_FILE=~/.claude/logs/memcan-mcp.log

# --- Ollama ---

# Ollama host — Ollama server URL for LLM inference.
# Default: http://ollama:11434 (bundled container) or http://localhost:11434 (standalone)
# OLLAMA_HOST=http://localhost:11434

# Bearer token for Ollama endpoint auth (e.g. behind a reverse proxy)
# OLLAMA_API_KEY=your-token-here

# --- Storage ---

# LanceDB storage path (embedded — no server needed)
# LANCEDB_PATH=~/.local/share/memcan/lancedb

# Default user ID for memory scoping
DEFAULT_USER_ID=global

# --- LLM & Embeddings ---

# Memory distillation (LLM fact extraction + dedup)
# Set to false to store memories as-is without LLM processing
# DISTILL_MEMORIES=true

# LLM model — use ollama:: prefix (e.g. ollama::qwen3.5:9b)
# LLM_MODEL=ollama::qwen3.5:9b

# Embedding model — fastembed in-process ONNX model name
# EMBED_MODEL=MultilingualE5Large

# --- Docker Compose ---

# Profiles to enable. "ollama" starts the bundled Ollama container (set by setup skill).
# "ollama,gpu" also starts Open WebUI. Leave empty to use an external Ollama.
# COMPOSE_PROFILES=ollama
