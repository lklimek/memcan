# Ollama host — used by the genai crate for LLM inference.
# Default: http://localhost:11434
# Set this if Ollama runs on a remote host.
# OLLAMA_HOST=http://localhost:11434

# Bearer token for Ollama endpoint auth (e.g. behind a reverse proxy)
# OLLAMA_API_KEY=your-token-here

# LanceDB storage path (embedded — no server needed)
# Default: ~/.local/share/mindojo/lancedb
# LANCEDB_PATH=~/.local/share/mindojo/lancedb

# Default user ID for memory scoping
DEFAULT_USER_ID=global
TECH_STACK=

# Memory distillation (LLM fact extraction + dedup)
# Set to false to store memories as-is without LLM processing
# DISTILL_MEMORIES=true

# LLM model — genai format with provider prefix (e.g. ollama::model, gpt-4o)
# LLM_MODEL=ollama::qwen3.5:4b

# Embedding model — fastembed in-process ONNX model name
# EMBED_MODEL=MultilingualE5Large

# Log file path (default: ~/.claude/logs/mindojo-mcp.log)
# LOG_FILE=~/.claude/logs/mindojo-mcp.log
